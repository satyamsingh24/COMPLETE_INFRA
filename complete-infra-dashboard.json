{
  "dashboard": {
    "id": null,
    "title": "Complete Infra - AWS Dashboard",
    "tags": ["cloudwatch", "ec2", "alb", "logs"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "EC2 CPU Utilization",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {"InstanceId": "i-0c26d6e666af4aa02"},
            "expression": "",
            "id": "cpu",
            "matchExact": true,
            "metricName": "CPUUtilization",
            "namespace": "AWS/EC2",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "color": {"mode": "palette-classic"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 80}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "EC2 Network In/Out",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {"InstanceId": "i-0c26d6e666af4aa02"},
            "metricName": "NetworkIn",
            "namespace": "AWS/EC2",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          },
          {
            "datasource": "CloudWatch",
            "dimensions": {"InstanceId": "i-0c26d6e666af4aa02"},
            "metricName": "NetworkOut",
            "namespace": "AWS/EC2",
            "period": "60",
            "refId": "B",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "bytes"}
        }
      },
      {
        "id": 3,
        "title": "ALB Request Count",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {"LoadBalancer": "app/complete-infra-alb/2d7da2c3d18073ae"},
            "metricName": "RequestCount",
            "namespace": "AWS/ApplicationELB",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Sum"]
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "short"}
        }
      },
      {
        "id": 4,
        "title": "ALB 5XX Errors",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {"LoadBalancer": "app/complete-infra-alb/2d7da2c3d18073ae"},
            "metricName": "HTTPCode_ELB_5XX_Count",
            "namespace": "AWS/ApplicationELB",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Sum"]
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"fixedColor": "red", "mode": "fixed"}
          }
        }
      },
      {
        "id": 5,
        "title": "ALB Target Response Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {"LoadBalancer": "app/complete-infra-alb/2d7da2c3d18073ae"},
            "metricName": "TargetResponseTime",
            "namespace": "AWS/ApplicationELB",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "s"}
        }
      },
      {
        "id": 6,
        "title": "EC2 Disk Read/Write",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {"InstanceId": "i-0c26d6e666af4aa02"},
            "metricName": "DiskReadBytes",
            "namespace": "AWS/EC2",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          },
          {
            "datasource": "CloudWatch",
            "dimensions": {"InstanceId": "i-0c26d6e666af4aa02"},
            "metricName": "DiskWriteBytes",
            "namespace": "AWS/EC2",
            "period": "60",
            "refId": "B",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "fieldConfig": {
          "defaults": {"unit": "bytes"}
        }
      },
      {
        "id": 7,
        "title": "ALB Healthy Hosts",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {
              "LoadBalancer": "app/complete-infra-alb/2d7da2c3d18073ae",
              "TargetGroup": "targetgroup/complete-infra-nginx-tg/acd4ca79e29b43eb"
            },
            "metricName": "HealthyHostCount",
            "namespace": "AWS/ApplicationELB",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "color": {"fixedColor": "green", "mode": "fixed"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        },
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
      },
      {
        "id": 8,
        "title": "Unhealthy Hosts",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {
              "LoadBalancer": "app/complete-infra-alb/2d7da2c3d18073ae",
              "TargetGroup": "targetgroup/complete-infra-nginx-tg/acd4ca79e29b43eb"
            },
            "metricName": "UnHealthyHostCount",
            "namespace": "AWS/ApplicationELB",
            "period": "60",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        },
        "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
      },
      {
        "id": 9,
        "title": "🪵 Application Logs (Backend)",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {},
            "expression": "fields @timestamp, @message | sort @timestamp desc | limit 200",
            "id": "backend_logs",
            "logGroups": [
              {
                "arn": "arn:aws:logs:ap-south-1:176583374037:log-group:/complete-infra/backend:*",
                "name": "/complete-infra/backend"
              }
            ],
            "matchExact": true,
            "metricName": "",
            "namespace": "",
            "period": "60",
            "queryMode": "Logs",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": false,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "dedupStrategy": "none",
          "sortOrder": "Descending"
        }
      },
      {
        "id": 10,
        "title": "🪵 Nginx Access Logs",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 38},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {},
            "expression": "fields @timestamp, @message | sort @timestamp desc | limit 200",
            "id": "nginx_logs",
            "logGroups": [
              {
                "arn": "arn:aws:logs:ap-south-1:176583374037:log-group:/complete-infra/nginx:*",
                "name": "/complete-infra/nginx"
              }
            ],
            "matchExact": true,
            "metricName": "",
            "namespace": "",
            "period": "60",
            "queryMode": "Logs",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": false,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "dedupStrategy": "none",
          "sortOrder": "Descending"
        }
      },
      {
        "id": 11,
        "title": "🪵 EC2 System Logs",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 48},
        "targets": [
          {
            "datasource": "CloudWatch",
            "dimensions": {},
            "expression": "fields @timestamp, @message | sort @timestamp desc | limit 200",
            "id": "system_logs",
            "logGroups": [
              {
                "arn": "arn:aws:logs:ap-south-1:176583374037:log-group:/complete-infra/system:*",
                "name": "/complete-infra/system"
              }
            ],
            "matchExact": true,
            "metricName": "",
            "namespace": "",
            "period": "60",
            "queryMode": "Logs",
            "refId": "A",
            "region": "ap-south-1",
            "statistics": ["Average"]
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": false,
          "showCommonLabels": false,
          "wrapLogMessage": true,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "dedupStrategy": "none",
          "sortOrder": "Descending"
        }
      }
    ],
    "time": {"from": "now-3h", "to": "now"},
    "refresh": "30s",
    "schemaVersion": 36,
    "version": 1
  },
  "overwrite": true,
  "folderId": 0
}