            "dashboard_arn": "arn:aws:cloudwatch::176583374037:dashboard/complete-infra-dashboard",
            "dashboard_body": "{\"widgets\":[{\"height\":1,\"properties\":{\"markdown\":\"# 🚀 complete-infra - Production Dashboard\\n\u003e Real-time monitoring | EC2 · ALB · ECR\"},\"type\":\"text\",\"width\":24,\"x\":0,\"y\":0},{\"height\":4,\"properties\":{\"metrics\":[[\"AWS/EC2\",\"CPUUtilization\",\"InstanceId\",\"i-0c26d6e666af4aa02\"]],\"period\":60,\"region\":\"ap-south-1\",\"stat\":\"Average\",\"title\":\"🖥️ EC2 CPU %\",\"view\":\"singleValue\"},\"type\":\"metric\",\"width\":6,\"x\":0,\"y\":1},{\"height\":4,\"properties\":{\"metrics\":[[\"AWS/ApplicationELB\",\"RequestCount\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\"]],\"period\":300,\"region\":\"ap-south-1\",\"stat\":\"Sum\",\"title\":\"🌐 Total Requests\",\"view\":\"singleValue\"},\"type\":\"metric\",\"width\":6,\"x\":6,\"y\":1},{\"height\":4,\"properties\":{\"metrics\":[[\"AWS/ApplicationELB\",\"HealthyHostCount\",\"TargetGroup\",\"targetgroup/complete-infra-nginx-tg/acd4ca79e29b43eb\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\"]],\"period\":60,\"region\":\"ap-south-1\",\"stat\":\"Average\",\"title\":\"✅ Healthy Hosts\",\"view\":\"singleValue\"},\"type\":\"metric\",\"width\":6,\"x\":12,\"y\":1},{\"height\":4,\"properties\":{\"metrics\":[[\"AWS/ApplicationELB\",\"HTTPCode_ELB_5XX_Count\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\"]],\"period\":300,\"region\":\"ap-south-1\",\"stat\":\"Sum\",\"title\":\"❌ 5XX Errors\",\"view\":\"singleValue\"},\"type\":\"metric\",\"width\":6,\"x\":18,\"y\":1},{\"height\":6,\"properties\":{\"annotations\":{\"horizontal\":[{\"color\":\"#ff7f0e\",\"label\":\"Warning (80%)\",\"value\":80}]},\"metrics\":[[\"AWS/EC2\",\"CPUUtilization\",\"InstanceId\",\"i-0c26d6e666af4aa02\"]],\"period\":60,\"region\":\"ap-south-1\",\"stat\":\"Average\",\"title\":\"🖥️ EC2 CPU Utilization (Line)\",\"view\":\"timeSeries\",\"yAxis\":{\"left\":{\"max\":100,\"min\":0}}},\"type\":\"metric\",\"width\":12,\"x\":0,\"y\":5},{\"height\":6,\"properties\":{\"metrics\":[[\"AWS/EC2\",\"NetworkIn\",\"InstanceId\",\"i-0c26d6e666af4aa02\",{\"color\":\"#2ca02c\",\"label\":\"Network In\"}],[\"AWS/EC2\",\"NetworkOut\",\"InstanceId\",\"i-0c26d6e666af4aa02\",{\"color\":\"#1f77b4\",\"label\":\"Network Out\"}]],\"period\":60,\"region\":\"ap-south-1\",\"stacked\":true,\"stat\":\"Average\",\"title\":\"📡 EC2 Network In/Out (Area)\",\"view\":\"timeSeries\"},\"type\":\"metric\",\"width\":12,\"x\":12,\"y\":5},{\"height\":6,\"properties\":{\"metrics\":[[\"AWS/ApplicationELB\",\"RequestCount\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\",{\"color\":\"#1f77b4\",\"label\":\"Requests\"}]],\"period\":300,\"region\":\"ap-south-1\",\"stat\":\"Sum\",\"title\":\"🌐 ALB Request Count (Bar)\",\"view\":\"bar\"},\"type\":\"metric\",\"width\":12,\"x\":0,\"y\":11},{\"height\":6,\"properties\":{\"annotations\":{\"horizontal\":[{\"color\":\"#d62728\",\"label\":\"Slow (5s)\",\"value\":5}]},\"metrics\":[[\"AWS/ApplicationELB\",\"TargetResponseTime\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\",{\"color\":\"#9467bd\",\"label\":\"Response Time\"}]],\"period\":60,\"region\":\"ap-south-1\",\"stat\":\"Average\",\"title\":\"⚡ ALB Response Time (ms)\",\"view\":\"timeSeries\"},\"type\":\"metric\",\"width\":12,\"x\":12,\"y\":11},{\"height\":6,\"properties\":{\"metrics\":[[\"AWS/ApplicationELB\",\"HTTPCode_ELB_4XX_Count\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\",{\"color\":\"#ff7f0e\",\"label\":\"4XX\"}],[\"AWS/ApplicationELB\",\"HTTPCode_ELB_5XX_Count\",\"LoadBalancer\",\"app/complete-infra-alb/2d7da2c3d18073ae\",{\"color\":\"#d62728\",\"label\":\"5XX\"}]],\"period\":300,\"region\":\"ap-south-1\",\"stacked\":true,\"stat\":\"Sum\",\"title\":\"🚨 ALB Error Codes (Stacked)\",\"view\":\"bar\"},\"type\":\"metric\",\"width\":12,\"x\":0,\"y\":17},{\"height\":6,\"properties\":{\"metrics\":[[\"AWS/ApplicationELB\",\"HealthyHostCount\",\"TargetGroup\",\"targetgroup/complete-infra-nginx-tg/acd4ca79e29b43eb\",\"LoadBalancer\"