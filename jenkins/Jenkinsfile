pipeline {
    agent any

    environment {
        AWS_REGION     = 'ap-south-1'
        AWS_ACCOUNT_ID = '176583374037'
        ECR_REPO       = 'complete-infra-app'
        ECR_URI        = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}"
        IMAGE_TAG      = "${BUILD_NUMBER}"
        APP_DIR        = '/home/ec2-user/COMPLETE_INFRA'
        EC2_IP         = '15.206.160.161'
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Code checkout...'
                checkout scm
            }
        }

        stage('ECR Login') {
            steps {
                echo '🔐 ECR Login...'
                sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                """
            }
        }

        stage('Build Backend Image') {
            steps {
                echo '🐳 Building Backend Docker image...'
                sh """
                    docker build -t ${ECR_REPO}-backend:${IMAGE_TAG} ./backend
                    docker tag ${ECR_REPO}-backend:${IMAGE_TAG} ${ECR_URI}-backend:${IMAGE_TAG}
                    docker tag ${ECR_REPO}-backend:${IMAGE_TAG} ${ECR_URI}-backend:latest
                """
            }
        }

        stage('Build Nginx Image') {
            steps {
                echo '🌐 Building Nginx Docker image...'
                sh """
                    docker build -t ${ECR_REPO}-nginx:${IMAGE_TAG} ./nginx
                    docker tag ${ECR_REPO}-nginx:${IMAGE_TAG} ${ECR_URI}-nginx:${IMAGE_TAG}
                    docker tag ${ECR_REPO}-nginx:${IMAGE_TAG} ${ECR_URI}-nginx:latest
                """
            }
        }

        stage('Push to ECR') {
            steps {
                echo '📤 Pushing images to ECR...'
                sh """
                    docker push ${ECR_URI}-backend:${IMAGE_TAG}
                    docker push ${ECR_URI}-backend:latest
                    docker push ${ECR_URI}-nginx:${IMAGE_TAG}
                    docker push ${ECR_URI}-nginx:latest
                """
            }
        }

        stage('Deploy on EC2') {
            steps {
                echo '🚀 Deploying with docker-compose on EC2...'
                sh """
                    # Code update karo
                    cd ${APP_DIR}
                    git pull origin main

                    # ECR login on EC2
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    # Docker compose up
                    docker-compose down || true
                    docker-compose pull || true
                    docker-compose up -d --build

                    echo '✅ App deployed!'
                """
            }
        }

        stage('Health Check') {
            steps {
                echo '✅ Health Check...'
                sh """
                    sleep 30
                    curl -f http://${EC2_IP}/actuator/health || \
                    curl -f http://${EC2_IP} || \
                    echo '⚠️ Health check failed - check manually'
                """
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline SUCCESS! App deployed!'
        }
        failure {
            echo '❌ Pipeline FAILED! Check logs.'
        }
    }
}
