pipeline {
    agent any

    environment {
        AWS_REGION        = 'ap-south-1'
        AWS_ACCOUNT_ID    = '176583374037'
        ECR_BACKEND       = '176583374037.dkr.ecr.ap-south-1.amazonaws.com/complete-infra-backend'
        ECR_NGINX         = '176583374037.dkr.ecr.ap-south-1.amazonaws.com/complete-infra-nginx'
        IMAGE_TAG         = "${BUILD_NUMBER}"
        ECS_CLUSTER       = 'complete-infra-cluster'
        ECS_SERVICE       = 'complete-infra-service'
        TASK_DEFINITION   = 'complete-infra-task'
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Code checkout...'
                checkout scm
            }
        }

        stage('ECR Login') {
            steps {
                echo '🔐 ECR Login...'
                sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                """
            }
        }

        stage('Ensure ECR Repos Exist') {
            steps {
                echo '📦 Ensuring ECR repositories exist...'
                sh """
                    aws ecr describe-repositories \
                        --repository-names complete-infra-app-backend \
                        --region ${AWS_REGION} 2>/dev/null || \
                    aws ecr create-repository \
                        --repository-name complete-infra-app-backend \
                        --region ${AWS_REGION} \
                        --image-scanning-configuration scanOnPush=true

                    aws ecr describe-repositories \
                        --repository-names complete-infra-app-nginx \
                        --region ${AWS_REGION} 2>/dev/null || \
                    aws ecr create-repository \
                        --repository-name complete-infra-app-nginx \
                        --region ${AWS_REGION} \
                        --image-scanning-configuration scanOnPush=true
                """
            }
        }

        stage('Build and Push Backend') {
            steps {
                echo '🐳 Building Backend...'
                sh """
                    docker build -t ${ECR_BACKEND}:${IMAGE_TAG} ./backend
                    docker tag ${ECR_BACKEND}:${IMAGE_TAG} ${ECR_BACKEND}:latest
                    docker push ${ECR_BACKEND}:${IMAGE_TAG}
                    docker push ${ECR_BACKEND}:latest
                """
            }
        }

        stage('Build and Push Nginx') {
            steps {
                echo '🌐 Building Nginx...'
                sh """
                    docker build -t ${ECR_NGINX}:${IMAGE_TAG} ./nginx
                    docker tag ${ECR_NGINX}:${IMAGE_TAG} ${ECR_NGINX}:latest
                    docker push ${ECR_NGINX}:${IMAGE_TAG}
                    docker push ${ECR_NGINX}:latest
                """
            }
        }

        stage('Deploy to ECS') {
            steps {
                echo '🚀 Deploying to ECS...'
                sh """
                    # ECS service force new deployment
                    aws ecs update-service \
                        --cluster ${ECS_CLUSTER} \
                        --service ${ECS_SERVICE} \
                        --force-new-deployment \
                        --region ${AWS_REGION}

                    # Deploy hone ka wait karo
                    aws ecs wait services-stable \
                        --cluster ${ECS_CLUSTER} \
                        --services ${ECS_SERVICE} \
                        --region ${AWS_REGION}

                    echo '✅ ECS Deployment complete!'
                """
            }
        }

        stage('Health Check') {
            steps {
                echo '✅ Health Check...'
                sh """
                    sleep 30
                    ALB_DNS=\$(aws elbv2 describe-load-balancers \
                        --names complete-infra-alb \
                        --region ${AWS_REGION} \
                        --query 'LoadBalancers[0].DNSName' \
                        --output text)
                    
                    echo "ALB DNS: \$ALB_DNS"
                    curl -f http://\$ALB_DNS && echo "✅ App OK!" || echo "⚠️ App not ready yet"
                """
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline SUCCESS! App ECS pe chal raha hai!'
        }
        failure {
            echo '❌ Pipeline FAILED!'
        }
    }
}