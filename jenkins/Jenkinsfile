pipeline {
    agent any

    environment {
        AWS_REGION     = 'ap-south-1'
        AWS_ACCOUNT_ID = '176583374037'
        ECR_BACKEND    = '176583374037.dkr.ecr.ap-south-1.amazonaws.com/complete-infra-app-backend'
        ECR_NGINX      = '176583374037.dkr.ecr.ap-south-1.amazonaws.com/complete-infra-app-nginx'
        IMAGE_TAG      = "${BUILD_NUMBER}"
        APP_DIR        = '/opt/app/COMPLETE_INFRA'
        GITHUB_URL     = 'https://github.com/satyamsingh24/COMPLETE_INFRA.git'
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Code checkout...'
                checkout scm
            }
        }

        stage('ECR Login') {
            steps {
                echo '🔐 ECR Login...'
                sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                """
            }
        }

        stage('Build and Push Backend') {
            steps {
                echo '🐳 Building Backend...'
                sh """
                    docker build -t ${ECR_BACKEND}:${IMAGE_TAG} ./backend
                    docker tag ${ECR_BACKEND}:${IMAGE_TAG} ${ECR_BACKEND}:latest
                    docker push ${ECR_BACKEND}:${IMAGE_TAG}
                    docker push ${ECR_BACKEND}:latest
                """
            }
        }

        stage('Build and Push Nginx') {
            steps {
                echo '🌐 Building Nginx...'
                sh """
                    docker build -t ${ECR_NGINX}:${IMAGE_TAG} ./nginx
                    docker tag ${ECR_NGINX}:${IMAGE_TAG} ${ECR_NGINX}:latest
                    docker push ${ECR_NGINX}:${IMAGE_TAG}
                    docker push ${ECR_NGINX}:latest
                """
            }
        }

        stage('Clone or Update') {
            steps {
                echo '📥 Clone/Update project...'
                sh """
                    # Jenkins ke liye /opt/app use karo
                    sudo mkdir -p /opt/app
                    sudo chown -R jenkins:jenkins /opt/app

                    if [ -d "${APP_DIR}/.git" ]; then
                        echo "Pulling latest..."
                        cd ${APP_DIR} && git pull origin main
                    else
                        echo "Cloning fresh..."
                        git clone ${GITHUB_URL} ${APP_DIR}
                    fi

                    echo "✅ Code ready:"
                    ls ${APP_DIR}
                """
            }
        }

        stage('Install docker-compose') {
            steps {
                echo '⚙️ Checking docker-compose...'
                sh """
                    if ! command -v docker-compose > /dev/null 2>&1; then
                        sudo curl -L https://github.com/docker/compose/releases/download/v2.24.0/docker-compose-linux-x86_64 \
                            -o /usr/local/bin/docker-compose
                        sudo chmod +x /usr/local/bin/docker-compose
                    fi
                    docker-compose --version
                """
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Deploying with docker-compose...'
                sh """
                    cd ${APP_DIR}

                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker-compose down --remove-orphans || true
                    docker-compose up -d --build

                    echo "✅ Running containers:"
                    docker-compose ps
                """
            }
        }

        stage('Health Check') {
            steps {
                echo '✅ Health Check...'
                sh """
                    sleep 60
                    curl -f http://localhost:8086/actuator/health && echo "✅ Backend OK" || echo "⚠️ Backend not ready"
                    curl -f http://localhost:80 && echo "✅ Nginx OK" || echo "⚠️ Nginx not ready"
                """
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline SUCCESS! App deployed!'
        }
        failure {
            echo '❌ Pipeline FAILED! Check logs.'
        }
    }
}
