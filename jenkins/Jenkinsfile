pipeline {
    agent any

    environment {
        AWS_REGION     = 'ap-south-1'
        AWS_ACCOUNT_ID = '176583374037'
        ECR_BACKEND = '176583374037.dkr.ecr.ap-south-1.amazonaws.com/complete-infra-app-backend'
        ECR_NGINX   = '176583374037.dkr.ecr.ap-south-1.amazonaws.com/complete-infra-app-nginx'
        IMAGE_TAG      = "${BUILD_NUMBER}"
        APP_DIR        = '/opt/app/COMPLETE_INFRA'

        // ✅ Grafana port fix — IP runtime pe fetch hogi automatically
        GRAFANA_PORT   = '3000'

        // ✅ CloudWatch Log Groups — apne actual log group names yahan daalo
        LOG_GROUP_BACKEND = '/complete-infra/backend'
        LOG_GROUP_NGINX   = '/complete-infra/nginx'
        LOG_GROUP_SYSTEM  = '/complete-infra/system'
    }

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Code checkout...'
                checkout scm
            }
        }

        stage('ECR Login') {
            steps {
                echo '🔐 ECR Login...'
                sh """
                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                """
            }
        }

        stage('Build and Push Backend') {
            steps {
                echo '🐳 Building Backend...'
                sh """
                    docker build -t ${ECR_BACKEND}:${IMAGE_TAG} ./backend
                    docker tag ${ECR_BACKEND}:${IMAGE_TAG} ${ECR_BACKEND}:latest
                    docker push ${ECR_BACKEND}:${IMAGE_TAG}
                    docker push ${ECR_BACKEND}:latest
                """
            }
        }

        stage('Build and Push Nginx') {
            steps {
                echo '🌐 Building Nginx...'
                sh """
                    docker build -t ${ECR_NGINX}:${IMAGE_TAG} ./nginx
                    docker tag ${ECR_NGINX}:${IMAGE_TAG} ${ECR_NGINX}:latest
                    docker push ${ECR_NGINX}:${IMAGE_TAG}
                    docker push ${ECR_NGINX}:latest
                """
            }
        }

        stage('Deploy') {
            steps {
                echo '🚀 Deploying with docker-compose...'
                sh """
                    cd ${APP_DIR}

                    git fetch origin main
                    git reset --hard origin/main

                    aws ecr get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin \
                    ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

                    docker-compose down --remove-orphans || true
                    docker-compose up -d
                    docker-compose ps
                """
            }
        }

        stage('Health Check') {
            steps {
                echo '✅ Health Check...'
                sh """
                    sleep 60
                    curl -f http://localhost:8085/actuator/health && echo "✅ Backend OK" || echo "⚠️ Backend not ready"
                    curl -f http://localhost:80 && echo "✅ Nginx OK" || echo "⚠️ Nginx not ready"
                """
            }
        }

        // ─────────────────────────────────────────────────────────────
        // NEW STAGE 1: Dynamic Grafana IP fetch karo (IP change hoti
        //              rehti hai — har build pe automatically detect)
        // ─────────────────────────────────────────────────────────────
       stage('Detect Grafana URL') {
    steps {
        echo '🔍 Detecting Grafana URL...'
        script {

            // Public IP try karo (best for browser access)
            def publicIp = sh(
                script: "curl -s http://169.254.169.254/latest/meta-data/public-ipv4 || true",
                returnStdout: true
            ).trim()

            // Private IP fallback
            def privateIp = sh(
                script: "curl -s http://169.254.169.254/latest/meta-data/local-ipv4 || true",
                returnStdout: true
            ).trim()

            // Default localhost
            def url = "http://localhost:${GRAFANA_PORT}"

            if (publicIp) {
                url = "http://${publicIp}:${GRAFANA_PORT}"
                echo "🌍 Using Public IP: ${url}"
            } else if (privateIp) {
                url = "http://${privateIp}:${GRAFANA_PORT}"
                echo "🏠 Using Private IP: ${url}"
            } else {
                echo "⚠️ IP fetch failed, using localhost"
            }

            // Health check
            def status = sh(
                script: "curl -s -o /dev/null -w '%{http_code}' ${url}/api/health",
                returnStdout: true
            ).trim()

            if (status == '200') {
                env.GRAFANA_URL = url
                echo "✅ Grafana Ready at: ${env.GRAFANA_URL}"
            } else {
                error "❌ Grafana not reachable at ${url}"
            }
        }
    }
}
        // ─────────────────────────────────────────────────────────────
        // NEW STAGE 2: CloudWatch DataSource setup (metrics + logs)
        // ─────────────────────────────────────────────────────────────
        stage('Setup Grafana CloudWatch DataSource') {
            steps {
                echo '📡 Grafana mein CloudWatch DataSource configure kar raha hun...'
                withCredentials([
                    usernamePassword(
                        credentialsId: 'GRAFANA_CREDS',
                        usernameVariable: 'GRAFANA_USER',
                        passwordVariable: 'GRAFANA_PASS'
                    )
                ]) {
                    sh '''
                        DS_EXISTS=$(curl -s -o /dev/null -w "%{http_code}" \
                            -u "${GRAFANA_USER}:${GRAFANA_PASS}" \
                            "${GRAFANA_URL}/api/datasources/name/CloudWatch")

                        if [ "$DS_EXISTS" = "200" ]; then
                            echo "✅ CloudWatch DataSource already exists — skip"
                        else
                            echo "➕ CloudWatch DataSource create kar raha hun..."
                            RESULT=$(curl -s -X POST \
                                -H "Content-Type: application/json" \
                                -u "${GRAFANA_USER}:${GRAFANA_PASS}" \
                                "${GRAFANA_URL}/api/datasources" \
                                -d '{
                                    "name": "CloudWatch",
                                    "type": "cloudwatch",
                                    "access": "proxy",
                                    "isDefault": true,
                                    "jsonData": {
                                        "authType": "default",
                                        "defaultRegion": "ap-south-1",
                                        "logsTimeout": "30m"
                                    }
                                }')
                            echo "Response: $RESULT"
                            echo "✅ CloudWatch DataSource (Metrics + Logs) created!"
                        fi
                    '''
                }
            }
        }

        // ─────────────────────────────────────────────────────────────
        // NEW STAGE 4: Dashboard import/update
        // ─────────────────────────────────────────────────────────────
        stage('Import Grafana Dashboard') {
            steps {
                echo '📊 Grafana mein Dashboard import kar raha hun...'
                withCredentials([
                    usernamePassword(
                        credentialsId: 'GRAFANA_CREDS',
                        usernameVariable: 'GRAFANA_USER',
                        passwordVariable: 'GRAFANA_PASS'
                    )
                ]) {
                    sh '''
                        DASHBOARD_FILE="complete-infra-dashboard.json"

                        if [ ! -f "$DASHBOARD_FILE" ]; then
                            echo "❌ Dashboard JSON file nahi mili: $DASHBOARD_FILE"
                            echo "   Repo root mein rakho: complete-infra-dashboard.json"
                            exit 1
                        fi

                        echo "📤 Dashboard import ho raha hai..."
                        RESPONSE=$(curl -s -X POST \
                            -H "Content-Type: application/json" \
                            -u "${GRAFANA_USER}:${GRAFANA_PASS}" \
                            "${GRAFANA_URL}/api/dashboards/import" \
                            -d @"${DASHBOARD_FILE}")

                        echo "Grafana Response: $RESPONSE"

                        # Status check
                        STATUS=$(echo $RESPONSE | grep -o '"status":"[^"]*"' | cut -d'"' -f4)
                        DASHBOARD_URL=$(echo $RESPONSE | grep -o '"url":"[^"]*"' | cut -d'"' -f4)

                        if [ "$STATUS" = "success" ] || [ "$STATUS" = "imported" ]; then
                            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                            echo "📊 GRAFANA DASHBOARD READY!"
                            echo "🔗 URL: ${GRAFANA_URL}${DASHBOARD_URL}"
                            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                        else
                            echo "⚠️  Response check karo upar — manually verify:"
                            echo "   ${GRAFANA_URL}/dashboards"
                        fi
                    '''
                }
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline SUCCESS! Grafana Dashboard pe CloudWatch data ab dikhega.'
        }
        failure {
            echo '❌ Pipeline FAILED! Logs check karo.'
        }
    }
}
