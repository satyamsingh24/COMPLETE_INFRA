{
  "title": "Complete Infra Dashboard",
  "uid": "complete-infra-main",
  "templating": {
    "list": [
      {
        "name": "region",
        "type": "constant",
        "query": "ap-south-1",
        "current": {"value": "ap-south-1", "text": "ap-south-1"},
        "hide": 2,
        "label": "Region"
      },
      {
        "name": "instance_id",
        "type": "query",
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "query": {
          "queryType": "dimensionValues",
          "namespace": "AWS/EC2",
          "metricName": "CPUUtilization",
          "dimensionKey": "InstanceId",
          "region": "ap-south-1"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "label": "EC2 Instance",
        "hide": 0,
        "sort": 1
      },
      {
        "name": "alb_name",
        "type": "query",
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "query": {
          "queryType": "dimensionValues",
          "namespace": "AWS/ApplicationELB",
          "metricName": "RequestCount",
          "dimensionKey": "LoadBalancer",
          "region": "ap-south-1"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "label": "Load Balancer",
        "hide": 0,
        "sort": 1
      },
      {
        "name": "target_group",
        "type": "query",
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "query": {
          "queryType": "dimensionValues",
          "namespace": "AWS/ApplicationELB",
          "metricName": "HealthyHostCount",
          "dimensionKey": "TargetGroup",
          "region": "ap-south-1"
        },
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "label": "Target Group",
        "hide": 0,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "EC2 CPU Utilization",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "dimensions": {"InstanceId": "$instance_id"},
        "metricName": "CPUUtilization",
        "namespace": "AWS/EC2",
        "period": "60",
        "refId": "A",
        "region": "$region",
        "statistics": ["Average"]
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 2,
      "title": "EC2 Network In/Out",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
          "dimensions": {"InstanceId": "$instance_id"},
          "metricName": "NetworkIn",
          "namespace": "AWS/EC2",
          "period": "60",
          "refId": "A",
          "region": "$region",
          "statistics": ["Average"]
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
          "dimensions": {"InstanceId": "$instance_id"},
          "metricName": "NetworkOut",
          "namespace": "AWS/EC2",
          "period": "60",
          "refId": "B",
          "region": "$region",
          "statistics": ["Average"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 3,
      "title": "ALB Request Count",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "dimensions": {"LoadBalancer": "$alb_name"},
        "metricName": "RequestCount",
        "namespace": "AWS/ApplicationELB",
        "period": "60",
        "refId": "A",
        "region": "$region",
        "statistics": ["Sum"]
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 4,
      "title": "ALB 5XX Errors",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "dimensions": {"LoadBalancer": "$alb_name"},
        "metricName": "HTTPCode_ELB_5XX_Count",
        "namespace": "AWS/ApplicationELB",
        "period": "60",
        "refId": "A",
        "region": "$region",
        "statistics": ["Sum"]
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 5,
      "title": "ALB Response Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "dimensions": {"LoadBalancer": "$alb_name"},
        "metricName": "TargetResponseTime",
        "namespace": "AWS/ApplicationELB",
        "period": "60",
        "refId": "A",
        "region": "$region",
        "statistics": ["Average"]
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 6,
      "title": "Healthy Hosts",
      "type": "stat",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
      "targets": [{
        "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
        "dimensions": {
          "LoadBalancer": "$alb_name",
          "TargetGroup": "$target_group"
        },
        "metricName": "HealthyHostCount",
        "namespace": "AWS/ApplicationELB",
        "period": "60",
        "refId": "A",
        "region": "$region",
        "statistics": ["Average"]
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "EC2 Disk Read/Write",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
      "targets": [
        {
          "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
          "dimensions": {"InstanceId": "$instance_id"},
          "metricName": "DiskReadBytes",
          "namespace": "AWS/EC2",
          "period": "60",
          "refId": "A",
          "region": "$region",
          "statistics": ["Average"]
        },
        {
          "datasource": {"type": "cloudwatch", "uid": "cloudwatch-main"},
          "dimensions": {"InstanceId": "$instance_id"},
          "metricName": "DiskWriteBytes",
          "namespace": "AWS/EC2",
          "period": "60",
          "refId": "B",
          "region": "$region",
          "statistics": ["Average"]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2}
        }
      }
    }
  ],
  "time": {"from": "now-3h", "to": "now"},
  "refresh": "30s",
  "schemaVersion": 36
}
